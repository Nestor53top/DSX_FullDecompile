<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives">
    <Style x:Key="DefaultToggleButtonStyle" TargetType="{x:Type ToggleButton}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ToggleButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ToggleButtonForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ToggleButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource ToggleButtonBorderThemeThickness}" />
        <Setter Property="Padding" Value="{DynamicResource ButtonPadding}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
        <Setter Property="FontWeight" Value="Normal" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualMargin" Value="-3" />
        <Setter Property="IsPressAndHoldEnabled" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <ControlTemplate.Triggers>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushPointerOver}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundPointerOver}" Property="Foreground" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundPressed}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushPressed}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundPressed}" Property="Foreground" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="False" />
                                <Condition Property="IsEnabled" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundDisabled}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushDisabled}" Property="BorderBrush" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="False" />
                                <Condition Property="IsPressed" Value="False" />
                                <Condition Property="IsEnabled" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundChecked}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundChecked}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushChecked}" Property="BorderBrush" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundCheckedPointerOver}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushCheckedPointerOver}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundCheckedPointerOver}" Property="Foreground" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundCheckedPressed}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundCheckedPressed}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushCheckedPressed}" Property="BorderBrush" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True" />
                                <Condition Property="IsEnabled" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundCheckedDisabled}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundCheckedDisabled}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushCheckedDisabled}" Property="BorderBrush" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Value="{Null}" Property="IsChecked" />
                                <Condition Property="IsMouseOver" Value="False" />
                                <Condition Property="IsPressed" Value="False" />
                                <Condition Property="IsEnabled" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundIndeterminate}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundIndeterminate}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushIndeterminate}" Property="BorderBrush" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Value="{Null}" Property="IsChecked" />
                                <Condition Property="IsMouseOver" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundIndeterminatePointerOver}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushIndeterminatePointerOver}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundIndeterminatePointerOver}" Property="Foreground" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Value="{Null}" Property="IsChecked" />
                                <Condition Property="IsPressed" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundIndeterminatePressed}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushIndeterminatePressed}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundIndeterminatePressed}" Property="Foreground" />
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Value="{Null}" Property="IsChecked" />
                                <Condition Property="IsEnabled" Value="False" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Background" Value="{DynamicResource ToggleButtonBackgroundIndeterminateDisabled}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource ToggleButtonForegroundIndeterminateDisabled}" Property="Foreground" />
                            <Setter TargetName="Border" Value="{DynamicResource ToggleButtonBorderBrushIndeterminateDisabled}" Property="BorderBrush" />
                        </MultiTrigger>
                    </ControlTemplate.Triggers>
                    <Border Name="Background" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}" SnapsToDevicePixels="True">
                        <Border Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter Name="ContentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Focusable="False" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Type ToggleButton}" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource DefaultToggleButtonStyle}" />
</ResourceDictionary>

