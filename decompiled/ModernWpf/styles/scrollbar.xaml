<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:root="clr-namespace:ModernWpf" xmlns:local="clr-namespace:ModernWpf.Controls" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives" xmlns:m="clr-namespace:ModernWpf.Markup" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <primitives:CornerRadiusFilterConverter x:Key="TopLeftCornerRadiusDoubleValueConverter" Filter="TopLeftValue" />
    <primitives:CornerRadiusFilterConverter x:Key="BottomRightCornerRadiusDoubleValueConverter" Filter="BottomRightValue" />
    <primitives:CornerRadiusFilterConverter x:Key="TopLeftCornerRadiusDoubleValueConverter8x" Filter="TopLeftValue" Scale="8" />
    <primitives:CornerRadiusFilterConverter x:Key="BottomRightCornerRadiusDoubleValueConverter8x" Filter="BottomRightValue" Scale="8" />
    <Style x:Key="DefaultThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource ThumbBackground}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="BorderBrush" Value="{DynamicResource ThumbBorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="MouseOver">
                                    <Storyboard>
                                        <DoubleAnimation Duration="0" To="1" TargetProperty="Opacity" TargetName="BackgroundPointerOver" />
                                        <DoubleAnimation Duration="0" To="0" TargetProperty="Opacity" TargetName="Background" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Duration="0" To="1" TargetProperty="Opacity" TargetName="BackgroundPressed" />
                                        <DoubleAnimation Duration="0" To="0" TargetProperty="Opacity" TargetName="Background" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </Grid.VisualStateGroups>
                        <Border Name="Background" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" />
                        <Border Name="BackgroundPointerOver" Background="{DynamicResource ThumbBackgroundPointerOver}" BorderBrush="{DynamicResource ThumbBorderBrushPointerOver}" BorderThickness="{TemplateBinding BorderThickness}" Opacity="0" />
                        <Border Name="BackgroundPressed" Background="{DynamicResource ThumbBackgroundPressed}" BorderBrush="{DynamicResource ThumbBorderBrushPressed}" BorderThickness="{TemplateBinding BorderThickness}" Opacity="0" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Type Thumb}" TargetType="{x:Type Thumb}" BasedOn="{StaticResource DefaultThumbStyle}" />
    <Duration x:Key="ScrollBarExpandDuration">00:00:00.1</Duration>
    <Duration x:Key="ScrollBarContractDuration">00:00:00.1</Duration>
    <Double x:Key="ScrollBarSize">16</Double>
    <Double x:Key="SmallScrollThumbScale">0.125</Double>
    <Double x:Key="SmallScrollThumbOffset">-2</Double>
    <Double x:Key="ScrollBarButtonArrowIconFontSize">8</Double>
    <TimeSpan x:Key="ScrollBarExpandBeginTime">00:00:00.40</TimeSpan>
    <TimeSpan x:Key="ScrollBarContractBeginTime">00:00:02.00</TimeSpan>
    <Style x:Key="RepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" Fill="{TemplateBinding Background}" SnapsToDevicePixels="True" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <ControlTemplate x:Key="ScrollBarButtonTemplate" TargetType="{x:Type RepeatButton}">
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBackgroundPointerOver}" Property="Background" />
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBorderBrushPointerOver}" Property="BorderBrush" />
                <Setter TargetName="Arrow" Value="{DynamicResource ScrollBarButtonArrowForegroundPointerOver}" Property="Foreground" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBackgroundPressed}" Property="Background" />
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBorderBrushPressed}" Property="BorderBrush" />
                <Setter TargetName="Arrow" Value="{DynamicResource ScrollBarButtonArrowForegroundPressed}" Property="Foreground" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBackgroundPressed}" Property="Background" />
                <Setter TargetName="Root" Value="{DynamicResource ScrollBarButtonBorderBrushDisabled}" Property="BorderBrush" />
                <Setter TargetName="Arrow" Value="{DynamicResource ScrollBarButtonArrowForegroundDisabled}" Property="Foreground" />
            </Trigger>
        </ControlTemplate.Triggers>
        <Border Name="Root" Background="{DynamicResource ScrollBarButtonBackground}" BorderBrush="{DynamicResource ScrollBarButtonBorderBrush}" SnapsToDevicePixels="True">
            <local:FontIconFallback Name="Arrow" FontFamily="{DynamicResource SymbolThemeFontFamily}" Data="{TemplateBinding Content}" Foreground="{DynamicResource ScrollBarButtonArrowForeground}" FontSize="{StaticResource DefaultThumbStyle}" />
        </Border>
    </ControlTemplate>
    <ControlTemplate x:Key="VerticalThumbTemplate" TargetType="{x:Type Thumb}">
        <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbBackground}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillPointerOver}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillPressed}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillDisabled}" Property="Fill" />
                <Setter TargetName="ThumbVisual" Property="Opacity" Value="0" />
            </Trigger>
        </ControlTemplate.Triggers>
        <Rectangle Name="ThumbVisual" Fill="{TemplateBinding Background}" SnapsToDevicePixels="True" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource DefaultThumbStyle}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource ScrollBarButtonArrowIconFontSize}}" />
    </ControlTemplate>
    <ControlTemplate x:Key="HorizontalThumbTemplate" TargetType="{x:Type Thumb}">
        <ControlTemplate.Triggers>
            <Trigger Property="IsExpanded" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbBackground}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillPointerOver}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsDragging" Value="True">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillPressed}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ThumbVisual" Value="{DynamicResource ScrollBarThumbFillDisabled}" Property="Fill" />
                <Setter TargetName="ThumbVisual" Property="Opacity" Value="0" />
            </Trigger>
        </ControlTemplate.Triggers>
        <Rectangle Name="ThumbVisual" Fill="{TemplateBinding Background}" SnapsToDevicePixels="True" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource DefaultThumbStyle}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource ScrollBarButtonArrowIconFontSize}}" />
    </ControlTemplate>
    <Style x:Key="DefaultScrollBarStyle" TargetType="{x:Type ScrollBar}">
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type ScrollBar}">
                            <ControlTemplate.Resources>
                                <StreamGeometry Name="ChevronLeft">M 14.091797 19.970703 L 4.111328 10 L 14.091797 0.029297 L 14.970703 0.908203 L 5.888672 10 L 14.970703 19.091797 Z</StreamGeometry>
                                <StreamGeometry Name="ChevronRight">M 5.029297 19.091797 L 14.111328 10 L 5.029297 0.908203 L 5.908203 0.029297 L 15.888672 10 L 5.908203 19.970703 Z</StreamGeometry>
                            </ControlTemplate.Resources>
                            <ControlTemplate.Triggers>
                                <Trigger SourceName="ConsciousStatesListener" Property="CurrentStateName" Value="Expanded">
                                    <Setter TargetName="Root" Value="{DynamicResource ScrollBarBackgroundPointerOver}" Property="Background" />
                                    <Setter TargetName="Root" Value="{DynamicResource ScrollBarBorderBrushPointerOver}" Property="BorderBrush" />
                                    <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource ScrollBarTrackStrokePointerOver}" Property="Stroke" />
                                    <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource ScrollBarTrackFillPointerOver}" Property="Fill" />
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Value="{DynamicResource ScrollBarBackgroundDisabled}" Property="Background" />
                                    <Setter TargetName="Root" Value="{DynamicResource ScrollBarBorderBrushDisabled}" Property="BorderBrush" />
                                    <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                                    <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource ScrollBarTrackStrokeDisabled}" Property="Stroke" />
                                    <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource ScrollBarTrackFillDisabled}" Property="Fill" />
                                    <Setter TargetName="PART_LineLeftButton" Property="Visibility" Value="Hidden" />
                                    <Setter TargetName="PART_LineRightButton" Property="Visibility" Value="Hidden" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                            <Border Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" SnapsToDevicePixels="true" CustomVisualStateManager="{root:SimpleVisualStateManager}">
                                <Border.Resources>
                                    <Storyboard Name="ExpandedToCollapsedStoryboard">
                                        <ColorAnimation Duration="{StaticResource SmallScrollThumbScale}" BeginTime="{StaticResource SmallScrollThumbOffset}" TargetName="HorizontalThumb" TargetProperty="(Panel.Background).(SolidColorBrush.Color)" To="{Binding Path=(primitives:ScrollBarHelper.CollapsedThumbBackgroundColor), RelativeSource={RelativeSource TemplatedParent}}" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarSize}" BeginTime="{StaticResource ScrollBarSize}" TargetName="HorizontalThumbScaleTransform" TargetProperty="ScaleY" To="{StaticResource ChevronDown}" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarButtonTemplate}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="HorizontalThumbTranslateTransform" TargetProperty="Y" To="{StaticResource ScrollBarContractBeginTime}" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="PART_LineRightButton" TargetProperty="Opacity" To="0" />
                                        <DoubleAnimation Duration="{StaticResource SmallScrollThumbScale}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="HorizontalLargeIncrease" TargetProperty="Opacity" To="0" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource SmallScrollThumbOffset}" TargetName="HorizontalLargeDecrease" TargetProperty="Opacity" To="0" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="PART_LineLeftButton" TargetProperty="Opacity" To="0" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="HorizontalTrackRect" TargetProperty="Opacity" To="0" />
                                        <ObjectAnimationUsingKeyFrames TargetName="HorizontalThumb" TargetProperty="(primitives:ControlHelper.CornerRadius)">
                                            <DiscreteObjectKeyFrame KeyTime="{m:KeyTime TimeSpan={StaticResource ScrollBarContractDuration}}">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <CornerRadius>0</CornerRadius>
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                    <Storyboard Name="ExpandedStoryboard">
                                        <ColorAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="HorizontalThumb" TargetProperty="(Panel.Background).(SolidColorBrush.Color)" To="{Binding Path=(primitives:ScrollBarHelper.ExpandedThumbBackgroundColor), RelativeSource={RelativeSource TemplatedParent}}" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="HorizontalThumbScaleTransform" TargetProperty="ScaleY" To="1.0" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="HorizontalThumbTranslateTransform" TargetProperty="Y" To="0" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="PART_LineRightButton" TargetProperty="Opacity" To="1" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="HorizontalLargeIncrease" TargetProperty="Opacity" To="1" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="HorizontalLargeDecrease" TargetProperty="Opacity" To="1" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="PART_LineLeftButton" TargetProperty="Opacity" To="1" />
                                        <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="HorizontalTrackRect" TargetProperty="Opacity" To="1" />
                                        <ObjectAnimationUsingKeyFrames TargetName="HorizontalThumb" TargetProperty="(primitives:ControlHelper.CornerRadius)">
                                            <DiscreteObjectKeyFrame KeyTime="{m:KeyTime TimeSpan={StaticResource ScrollBarExpandDuration}}">
                                                <DiscreteObjectKeyFrame.Value>
                                                    <CornerRadius>0</CornerRadius>
                                                </DiscreteObjectKeyFrame.Value>
                                            </DiscreteObjectKeyFrame>
                                        </ObjectAnimationUsingKeyFrames>
                                        <BooleanAnimationUsingKeyFrames TargetName="HorizontalThumb" TargetProperty="(primitives:ScrollBarThumbHelper.IsExpanded)">
                                            <DiscreteBooleanKeyFrame KeyTime="0:0:0.5" Value="True" />
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </Border.Resources>
                                <Border.VisualStateGroups>
                                    <VisualStateGroup x:Name="ConsciousStates" Listener="{primitives:VisualStateGroupListener Name=ConsciousStatesListener}">
                                        <VisualStateGroup.Transitions>
                                            <VisualTransition From="Expanded" To="Collapsed" Storyboard="{StaticResource ScrollBarExpandBeginTime}" />
                                        </VisualStateGroup.Transitions>
                                        <VisualState x:Name="Collapsed" />
                                        <VisualState x:Name="Expanded" Storyboard="{StaticResource ScrollBarExpandDuration}" />
                                    </VisualStateGroup>
                                </Border.VisualStateGroups>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Rectangle Name="HorizontalTrackRect" Opacity="0" ColumnSpan="3" Margin="0" StrokeThickness="{DynamicResource ScrollBarTrackBorderThemeThickness}" Fill="{DynamicResource ScrollBarTrackFill}" Stroke="{DynamicResource ScrollBarTrackStroke}" />
                                    <RepeatButton Name="PART_LineLeftButton" Command="{Static LineLeftCommand}" Opacity="0" Column="0" MinHeight="{StaticResource ScrollBarExpandBeginTime}" IsTabStop="False" Margin="0" Content="{StaticResource ScrollBarExpandDuration}" Template="{StaticResource ScrollBarExpandBeginTime}" Width="{StaticResource ScrollBarExpandBeginTime}" VerticalAlignment="Center" />
                                    <Track Name="PART_Track" Column="1" DecreaseRepeatButton="{RepeatButton Name=HorizontalLargeDecrease, Command={Static PageLeftCommand}, Style={StaticResource ExpandedToCollapsedStoryboard}, Opacity=0}" IncreaseRepeatButton="{RepeatButton Name=HorizontalLargeIncrease, Command={Static PageRightCommand}, Style={StaticResource ExpandedStoryboard}, Opacity=0}">
                                        <Track.Resources>
                                            <Double>32</Double>
                                        </Track.Resources>
                                        <Track.Thumb>
                                            <Thumb Name="HorizontalThumb" Background="{DynamicResource ScrollBarPanningThumbBackground}" Template="{StaticResource ScrollBarSize}" Height="{StaticResource ChevronLeft}" VerticalAlignment="Bottom" RenderTransformOrigin="0.5,1" CornerRadius="{TemplateBinding CornerRadius}">
                                                <Thumb.RenderTransform>
                                                    <TransformGroup>
                                                        <ScaleTransform x:Name="HorizontalThumbScaleTransform" ScaleX="1.0" ScaleY="{StaticResource ScrollBarButtonTemplate}" />
                                                        <TranslateTransform x:Name="HorizontalThumbTranslateTransform" X="0" Y="{StaticResource ScrollBarSize}" />
                                                    </TransformGroup>
                                                </Thumb.RenderTransform>
                                            </Thumb>
                                        </Track.Thumb>
                                    </Track>
                                    <RepeatButton Name="PART_LineRightButton" Command="{Static LineRightCommand}" Opacity="0" Column="2" MinHeight="{StaticResource RepeatButtonTransparent}" IsTabStop="False" Margin="0" Content="{StaticResource RepeatButtonTransparent}" Template="{StaticResource HorizontalThumbTemplate}" Width="{StaticResource ScrollBarSize}" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Trigger>
            <DataTrigger Binding="{Binding Path=(SystemParameters.HighContrast)}" Value="true">
                <Setter Property="CollapsedThumbBackgroundColor" Value="{DynamicResource {x:Static ControlTextColor}}" />
                <Setter Property="ExpandedThumbBackgroundColor" Value="{DynamicResource {x:Static ControlTextColor}}" />
            </DataTrigger>
        </Style.Triggers>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsPressAndHoldEnabled" Value="false" />
        <Setter Property="IsFlicksEnabled" Value="false" />
        <Setter Property="MinWidth" Value="{StaticResource DefaultThumbStyle}" />
        <Setter Property="MinHeight" Value="{StaticResource ScrollBarButtonArrowIconFontSize}" />
        <Setter Property="Background" Value="{DynamicResource ScrollBarBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource ScrollBarForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource ScrollBarBorderBrush}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="IsEnabled" Value="True" />
        <Setter Property="CollapsedThumbBackgroundColor" Value="{DynamicResource ScrollBarPanningThumbBackgroundColor}" />
        <Setter Property="ExpandedThumbBackgroundColor" Value="{DynamicResource ScrollBarThumbBackgroundColor}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <ControlTemplate.Resources>
                        <StreamGeometry Name="ChevronDown">M 18.935547 4.560547 L 19.814453 5.439453 L 10 15.253906 L 0.185547 5.439453 L 1.064453 4.560547 L 10 13.496094 Z</StreamGeometry>
                        <StreamGeometry Name="ChevronUp">M 19.091797 14.970703 L 10 5.888672 L 0.908203 14.970703 L 0.029297 14.091797 L 10 4.111328 L 19.970703 14.091797 Z</StreamGeometry>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="ConsciousStatesListener" Property="CurrentStateName" Value="Expanded">
                            <Setter TargetName="Root" Value="{DynamicResource ScrollBarBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="Root" Value="{DynamicResource ScrollBarBorderBrushPointerOver}" Property="BorderBrush" />
                            <Setter TargetName="VerticalTrackRect" Value="{DynamicResource ScrollBarTrackStrokePointerOver}" Property="Stroke" />
                            <Setter TargetName="VerticalTrackRect" Value="{DynamicResource ScrollBarTrackFillPointerOver}" Property="Fill" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Value="{DynamicResource ScrollBarBackgroundDisabled}" Property="Background" />
                            <Setter TargetName="Root" Value="{DynamicResource ScrollBarBorderBrushDisabled}" Property="BorderBrush" />
                            <Setter TargetName="Root" Property="Opacity" Value="0.5" />
                            <Setter TargetName="VerticalTrackRect" Value="{DynamicResource ScrollBarTrackStrokeDisabled}" Property="Stroke" />
                            <Setter TargetName="VerticalTrackRect" Value="{DynamicResource ScrollBarTrackFillDisabled}" Property="Fill" />
                            <Setter TargetName="PART_LineUpButton" Property="Visibility" Value="Hidden" />
                            <Setter TargetName="PART_LineDownButton" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Border Name="Root" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" SnapsToDevicePixels="true" CustomVisualStateManager="{root:SimpleVisualStateManager}">
                        <Border.Resources>
                            <Storyboard Name="ExpandedToCollapsedStoryboard">
                                <ColorAnimation Duration="{StaticResource TopLeftCornerRadiusDoubleValueConverter8x}" BeginTime="{StaticResource BottomRightCornerRadiusDoubleValueConverter}" TargetName="VerticalThumb" TargetProperty="(Panel.Background).(SolidColorBrush.Color)" To="{Binding Path=(primitives:ScrollBarHelper.CollapsedThumbBackgroundColor), RelativeSource={RelativeSource TemplatedParent}}" />
                                <DoubleAnimation Duration="{StaticResource TopLeftCornerRadiusDoubleValueConverter}" BeginTime="{StaticResource BottomRightCornerRadiusDoubleValueConverter8x}" TargetName="VerticalThumbScaleTransform" TargetProperty="ScaleX" To="{StaticResource ScrollBarSize}" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarSize}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="VerticalThumbTranslateTransform" TargetProperty="X" To="{StaticResource ScrollBarContractBeginTime}" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="PART_LineDownButton" TargetProperty="Opacity" To="0" />
                                <DoubleAnimation Duration="{StaticResource SmallScrollThumbScale}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="VerticalLargeIncrease" TargetProperty="Opacity" To="0" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource SmallScrollThumbOffset}" TargetName="VerticalLargeDecrease" TargetProperty="Opacity" To="0" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="PART_LineUpButton" TargetProperty="Opacity" To="0" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractDuration}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="VerticalTrackRect" TargetProperty="Opacity" To="0" />
                                <ObjectAnimationUsingKeyFrames TargetName="VerticalThumb" TargetProperty="(primitives:ControlHelper.CornerRadius)">
                                    <DiscreteObjectKeyFrame KeyTime="{m:KeyTime TimeSpan={StaticResource ScrollBarContractDuration}}">
                                        <DiscreteObjectKeyFrame.Value>
                                            <CornerRadius>0</CornerRadius>
                                        </DiscreteObjectKeyFrame.Value>
                                    </DiscreteObjectKeyFrame>
                                </ObjectAnimationUsingKeyFrames>
                            </Storyboard>
                            <Storyboard Name="ExpandedStoryboard">
                                <ColorAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="VerticalThumb" TargetProperty="(Panel.Background).(SolidColorBrush.Color)" To="{Binding Path=(primitives:ScrollBarHelper.ExpandedThumbBackgroundColor), RelativeSource={RelativeSource TemplatedParent}}" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractDuration}" TargetName="VerticalThumbScaleTransform" TargetProperty="ScaleX" To="1.0" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarContractBeginTime}" BeginTime="{StaticResource ScrollBarContractBeginTime}" TargetName="VerticalThumbTranslateTransform" TargetProperty="X" To="0" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="PART_LineDownButton" TargetProperty="Opacity" To="1" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="VerticalLargeIncrease" TargetProperty="Opacity" To="1" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="VerticalLargeDecrease" TargetProperty="Opacity" To="1" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="PART_LineUpButton" TargetProperty="Opacity" To="1" />
                                <DoubleAnimation Duration="{StaticResource ScrollBarExpandDuration}" BeginTime="{StaticResource ScrollBarExpandBeginTime}" TargetName="VerticalTrackRect" TargetProperty="Opacity" To="1" />
                                <ObjectAnimationUsingKeyFrames TargetName="VerticalThumb" TargetProperty="(primitives:ControlHelper.CornerRadius)">
                                    <DiscreteObjectKeyFrame KeyTime="{m:KeyTime TimeSpan={StaticResource ScrollBarExpandDuration}}">
                                        <DiscreteObjectKeyFrame.Value>
                                            <CornerRadius>0</CornerRadius>
                                        </DiscreteObjectKeyFrame.Value>
                                    </DiscreteObjectKeyFrame>
                                </ObjectAnimationUsingKeyFrames>
                                <BooleanAnimationUsingKeyFrames TargetName="VerticalThumb" TargetProperty="(primitives:ScrollBarThumbHelper.IsExpanded)">
                                    <DiscreteBooleanKeyFrame KeyTime="0:0:0.5" Value="True" />
                                </BooleanAnimationUsingKeyFrames>
                            </Storyboard>
                        </Border.Resources>
                        <Border.VisualStateGroups>
                            <VisualStateGroup x:Name="ConsciousStates" Listener="{primitives:VisualStateGroupListener Name=ConsciousStatesListener}">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="Expanded" To="Collapsed" Storyboard="{StaticResource ScrollBarExpandBeginTime}" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Collapsed" />
                                <VisualState x:Name="Expanded" Storyboard="{StaticResource ScrollBarExpandDuration}" />
                            </VisualStateGroup>
                        </Border.VisualStateGroups>
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Rectangle Name="VerticalTrackRect" Opacity="0" RowSpan="3" Margin="0" StrokeThickness="{DynamicResource ScrollBarTrackBorderThemeThickness}" Fill="{DynamicResource ScrollBarTrackFill}" Stroke="{DynamicResource ScrollBarTrackStroke}" />
                            <RepeatButton Name="PART_LineUpButton" Command="{Static LineUpCommand}" Opacity="0" Height="{StaticResource ScrollBarExpandBeginTime}" MinWidth="{StaticResource ScrollBarExpandDuration}" IsTabStop="False" Margin="0" Row="0" Content="{StaticResource ScrollBarExpandBeginTime}" Template="{StaticResource ScrollBarExpandBeginTime}" HorizontalAlignment="Center" />
                            <Track Name="PART_Track" Row="1" IsDirectionReversed="true" DecreaseRepeatButton="{RepeatButton Name=VerticalLargeDecrease, Command={Static PageUpCommand}, Style={StaticResource ExpandedToCollapsedStoryboard}, Opacity=0}" IncreaseRepeatButton="{RepeatButton Name=VerticalLargeIncrease, Command={Static PageDownCommand}, Style={StaticResource ExpandedStoryboard}, Opacity=0}">
                                <Track.Resources>
                                    <Double>32</Double>
                                </Track.Resources>
                                <Track.Thumb>
                                    <Thumb Name="VerticalThumb" Background="{DynamicResource ScrollBarPanningThumbBackground}" Template="{StaticResource ScrollBarSize}" Width="{StaticResource ScrollBarSize}" RenderTransformOrigin="1,0.5" CornerRadius="{TemplateBinding CornerRadius}">
                                        <Thumb.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform x:Name="VerticalThumbScaleTransform" ScaleX="{StaticResource ChevronUp}" ScaleY="1.0" />
                                                <TranslateTransform x:Name="VerticalThumbTranslateTransform" X="{StaticResource ScrollBarButtonTemplate}" Y="0" />
                                            </TransformGroup>
                                        </Thumb.RenderTransform>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                            <RepeatButton Name="PART_LineDownButton" Command="{Static LineDownCommand}" Opacity="0" Height="{StaticResource RepeatButtonTransparent}" MinWidth="{StaticResource RepeatButtonTransparent}" IsTabStop="False" Margin="0" Row="2" Content="{StaticResource VerticalThumbTemplate}" Template="{StaticResource ScrollBarSize}" HorizontalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Type ScrollBar}" TargetType="{x:Type ScrollBar}" BasedOn="{StaticResource DefaultThumbStyle}" />
</ResourceDictionary>

