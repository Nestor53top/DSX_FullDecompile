<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Thickness x:Key="TimePickerTopHeaderMargin">0,0,0,4</Thickness>
    <Double x:Key="TimePickerFlyoutPresenterHighlightHeight">40</Double>
    <Double x:Key="TimePickerFlyoutPresenterAcceptDismissHostGridHeight">41</Double>
    <Double x:Key="TimePickerThemeMinWidth">242</Double>
    <Double x:Key="TimePickerThemeMaxWidth">456</Double>
    <Double x:Key="TimePickerFlyoutPresenterItemHeight">40</Double>
    <Double x:Key="TimePickerPopupVerticalOffset">18.5</Double>
    <Thickness x:Key="TimePickerFlyoutPresenterItemPadding">0,3,0,6</Thickness>
    <Thickness x:Key="TimePickerHostPadding">0,3,0,6</Thickness>
    <Style x:Key="DateTimePickerFlyoutButtonStyle" TargetType="{x:Type ButtonBase}">
        <Setter Property="Background" Value="{DynamicResource DateTimePickerFlyoutButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualMargin" Value="0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ButtonBase}">
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Border" Value="{DynamicResource DateTimePickerFlyoutButtonBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource DateTimePickerFlyoutButtonBorderBrushPointerOver}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource DateTimePickerFlyoutButtonForegroundPointerOver}" Property="Foreground" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Border" Value="{DynamicResource DateTimePickerFlyoutButtonBackgroundPressed}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource DateTimePickerFlyoutButtonBorderBrushPressed}" Property="BorderBrush" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource DateTimePickerFlyoutButtonForegroundPressed}" Property="Foreground" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Grid Background="{TemplateBinding Background}">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="{DynamicResource DateTimePickerFlyoutButtonBorderBrush}" BorderThickness="{DynamicResource DateTimeFlyoutButtonBorderThickness}" Padding="{TemplateBinding Padding}" CornerRadius="{TemplateBinding CornerRadius}">
                            <ContentPresenter Name="ContentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

