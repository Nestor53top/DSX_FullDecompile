<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:ModernWpf.Controls" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="ToolTip.xaml" />
    </ResourceDictionary.MergedDictionaries>
    <Thickness x:Key="SliderTopHeaderMargin">0,0,0,4</Thickness>
    <Double x:Key="SliderPreContentMargin">15</Double>
    <Double x:Key="SliderPostContentMargin">15</Double>
    <Double x:Key="SliderHorizontalHeight">32</Double>
    <Double x:Key="SliderVerticalWidth">32</Double>
    <CornerRadius x:Key="SliderThumbCornerRadius">10</CornerRadius>
    <Double x:Key="SliderHorizontalThumbWidth">20</Double>
    <Double x:Key="SliderHorizontalThumbHeight">20</Double>
    <Double x:Key="SliderVerticalThumbWidth">20</Double>
    <Double x:Key="SliderVerticalThumbHeight">20</Double>
    <primitives:CornerRadiusFilterConverter x:Key="TopLeftCornerRadiusDoubleValueConverter" Filter="TopLeftValue" />
    <primitives:CornerRadiusFilterConverter x:Key="BottomRightCornerRadiusDoubleValueConverter" Filter="BottomRightValue" />
    <Style x:Key="RepeatButtonTransparent" TargetType="{x:Type RepeatButton}">
        <Setter Property="OverridesDefaultStyle" Value="true" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="false" />
        <Setter Property="IsTabStop" Value="false" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type RepeatButton}">
                    <Rectangle Width="{TemplateBinding Width}" Height="{TemplateBinding Height}" Fill="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SliderThumbStyle" TargetType="{x:Type Thumb}">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="{DynamicResource SliderThumbBackground}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="{DynamicResource SliderThumbCornerRadius}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="SliderAutoToolTipStyle" TargetType="{x:Type ToolTip}" BasedOn="{StaticResource DefaultToolTipStyle}">
        <Setter Property="IsEnabled" Value="True" />
    </Style>
    <ControlTemplate x:Key="SliderHorizontal" TargetType="{x:Type Slider}">
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="TopTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="BottomTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="TopTickBar" Property="Visibility" Value="Visible" />
                <Setter TargetName="BottomTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource SliderTrackFillPointerOver}" Property="Fill" />
                <Setter TargetName="HorizontalThumb" Value="{DynamicResource SliderThumbBackgroundPointerOver}" Property="Background" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundPointerOver}" Property="Background" />
                <Setter TargetName="HorizontalDecreaseRect" Value="{DynamicResource SliderTrackValueFillPointerOver}" Property="Fill" />
            </Trigger>
            <Trigger SourceName="HorizontalThumb" Property="IsDragging" Value="True">
                <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource SliderTrackFillPressed}" Property="Fill" />
                <Setter TargetName="HorizontalThumb" Value="{DynamicResource SliderThumbBackgroundPressed}" Property="Background" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundPressed}" Property="Background" />
                <Setter TargetName="HorizontalDecreaseRect" Value="{DynamicResource SliderTrackValueFillPressed}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="HeaderContentPresenter" Value="{DynamicResource SliderHeaderForegroundDisabled}" Property="Foreground" />
                <Setter TargetName="HorizontalDecreaseRect" Value="{DynamicResource SliderTrackValueFillDisabled}" Property="Fill" />
                <Setter TargetName="HorizontalTrackRect" Value="{DynamicResource SliderTrackFillDisabled}" Property="Fill" />
                <Setter TargetName="HorizontalThumb" Value="{DynamicResource SliderThumbBackgroundDisabled}" Property="Background" />
                <Setter TargetName="TopTickBar" Value="{DynamicResource SliderTickBarFillDisabled}" Property="Fill" />
                <Setter TargetName="BottomTickBar" Value="{DynamicResource SliderTickBarFillDisabled}" Property="Fill" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundDisabled}" Property="Background" />
            </Trigger>
        </ControlTemplate.Triggers>
        <Grid Margin="{TemplateBinding Padding}" SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <local:ContentPresenterEx Name="HeaderContentPresenter" Row="0" Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" FontWeight="{DynamicResource SliderHeaderThemeFontWeight}" Foreground="{DynamicResource SliderHeaderForeground}" Margin="{DynamicResource SliderTopHeaderMargin}" TextWrapping="Wrap" Visibility="{TemplateBinding HeaderVisibility}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
            <Grid Name="SliderContainer" Row="1" Background="{DynamicResource SliderContainerBackground}" IsTemplateFocusTarget="True">
                <Grid Name="HorizontalTemplate" MinHeight="{DynamicResource SliderHorizontalHeight}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition PixelHeight="{DynamicResource SliderPreContentMargin}" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition PixelHeight="{DynamicResource SliderPostContentMargin}" />
                    </Grid.RowDefinitions>
                    <Rectangle Name="HorizontalTrackRect" Fill="{TemplateBinding Background}" Height="{DynamicResource SliderTrackThemeHeight}" Row="1" ColumnSpan="3" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource DefaultToolTipStyle}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}" />
                    <Rectangle Name="HorizontalDecreaseRect" Fill="{TemplateBinding Foreground}" Row="1" Width="{Binding ActualWidth , ElementName=HorizontalDecrease}" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}" />
                    <TickBar Name="TopTickBar" Placement="Top" Visibility="Collapsed" Fill="{DynamicResource SliderTickBarFill}" Height="{DynamicResource SliderOutsideTickBarThemeHeight}" VerticalAlignment="Bottom" Margin="0,0,0,4" ColumnSpan="3" />
                    <TickBar Name="BottomTickBar" Placement="Bottom" Visibility="Collapsed" Fill="{DynamicResource SliderTickBarFill}" Height="{DynamicResource SliderOutsideTickBarThemeHeight}" VerticalAlignment="Top" Margin="0,4,0,0" Row="2" ColumnSpan="3" />
                    <Track Name="PART_Track" Row="0" RowSpan="3" Column="0" ColumnSpan="3" DecreaseRepeatButton="{RepeatButton Name=HorizontalDecrease, Command={Static DecreaseLarge}, Style={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" IncreaseRepeatButton="{RepeatButton Command={Static IncreaseLarge}, Style={StaticResource RepeatButtonTransparent}}">
                        <Track.Thumb>
                            <Thumb Name="HorizontalThumb" Style="{StaticResource RepeatButtonTransparent}" DataContext="{TemplateBinding Value}" Height="{DynamicResource SliderHorizontalThumbHeight}" Width="{DynamicResource SliderHorizontalThumbWidth}" FocusVisualMargin="-14,-6,-14,-6">
                                <Thumb.Resources>
                                    <Style TargetType="{x:Type ToolTip}" BasedOn="{StaticResource SliderThumbStyle}" />
                                </Thumb.Resources>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </Grid>
            </Grid>
        </Grid>
    </ControlTemplate>
    <ControlTemplate x:Key="SliderVertical" TargetType="{x:Type Slider}">
        <ControlTemplate.Triggers>
            <Trigger Property="TickPlacement" Value="TopLeft">
                <Setter TargetName="LeftTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="BottomRight">
                <Setter TargetName="RightTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="TickPlacement" Value="Both">
                <Setter TargetName="LeftTickBar" Property="Visibility" Value="Visible" />
                <Setter TargetName="RightTickBar" Property="Visibility" Value="Visible" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="VerticalTrackRect" Value="{DynamicResource SliderTrackFillPointerOver}" Property="Fill" />
                <Setter TargetName="VerticalThumb" Value="{DynamicResource SliderThumbBackgroundPointerOver}" Property="Background" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundPointerOver}" Property="Background" />
                <Setter TargetName="VerticalDecreaseRect" Value="{DynamicResource SliderTrackValueFillPointerOver}" Property="Fill" />
            </Trigger>
            <Trigger SourceName="VerticalThumb" Property="IsDragging" Value="True">
                <Setter TargetName="VerticalTrackRect" Value="{DynamicResource SliderTrackFillPressed}" Property="Fill" />
                <Setter TargetName="VerticalThumb" Value="{DynamicResource SliderThumbBackgroundPressed}" Property="Background" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundPressed}" Property="Background" />
                <Setter TargetName="VerticalDecreaseRect" Value="{DynamicResource SliderTrackValueFillPressed}" Property="Fill" />
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="HeaderContentPresenter" Value="{DynamicResource SliderHeaderForegroundDisabled}" Property="Foreground" />
                <Setter TargetName="VerticalDecreaseRect" Value="{DynamicResource SliderTrackValueFillDisabled}" Property="Fill" />
                <Setter TargetName="VerticalTrackRect" Value="{DynamicResource SliderTrackFillDisabled}" Property="Fill" />
                <Setter TargetName="VerticalThumb" Value="{DynamicResource SliderThumbBackgroundDisabled}" Property="Background" />
                <Setter TargetName="LeftTickBar" Value="{DynamicResource SliderTickBarFillDisabled}" Property="Fill" />
                <Setter TargetName="RightTickBar" Value="{DynamicResource SliderTickBarFillDisabled}" Property="Fill" />
                <Setter TargetName="SliderContainer" Value="{DynamicResource SliderContainerBackgroundDisabled}" Property="Background" />
            </Trigger>
        </ControlTemplate.Triggers>
        <Grid Margin="{TemplateBinding Padding}" SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <local:ContentPresenterEx Name="HeaderContentPresenter" Row="0" Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}" FontWeight="{DynamicResource SliderHeaderThemeFontWeight}" Foreground="{DynamicResource SliderHeaderForeground}" Margin="{DynamicResource SliderTopHeaderMargin}" TextWrapping="Wrap" Visibility="{TemplateBinding HeaderVisibility}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
            <Grid Name="SliderContainer" Row="1" Background="{DynamicResource SliderContainerBackground}" IsTemplateFocusTarget="True">
                <Grid Name="VerticalTemplate" MinWidth="{DynamicResource SliderVerticalWidth}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition PixelWidth="{DynamicResource SliderPreContentMargin}" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition PixelWidth="{DynamicResource SliderPostContentMargin}" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Name="VerticalTrackRect" Fill="{TemplateBinding Background}" Width="{DynamicResource SliderTrackThemeHeight}" Column="1" RowSpan="3" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource DefaultToolTipStyle}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}" />
                    <Rectangle Name="VerticalDecreaseRect" Fill="{TemplateBinding Foreground}" Column="1" Row="2" Height="{Binding ActualHeight , ElementName=VerticalDecrease}" RadiusX="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" RadiusY="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource TopLeftCornerRadiusDoubleValueConverter}}" />
                    <TickBar Name="LeftTickBar" Placement="Left" Visibility="Collapsed" Fill="{DynamicResource SliderTickBarFill}" Width="{DynamicResource SliderOutsideTickBarThemeHeight}" HorizontalAlignment="Right" Margin="0,0,4,0" RowSpan="3" />
                    <TickBar Name="RightTickBar" Placement="Right" Visibility="Collapsed" Fill="{DynamicResource SliderTickBarFill}" Width="{DynamicResource SliderOutsideTickBarThemeHeight}" HorizontalAlignment="Left" Margin="4,0,0,0" Column="2" RowSpan="3" />
                    <Track Name="PART_Track" Row="0" RowSpan="3" Column="0" ColumnSpan="3" DecreaseRepeatButton="{RepeatButton Name=VerticalDecrease, Command={Static DecreaseLarge}, Style={StaticResource BottomRightCornerRadiusDoubleValueConverter}}" IncreaseRepeatButton="{RepeatButton Command={Static IncreaseLarge}, Style={StaticResource RepeatButtonTransparent}}">
                        <Track.Thumb>
                            <Thumb Name="VerticalThumb" Style="{StaticResource RepeatButtonTransparent}" DataContext="{TemplateBinding Value}" Width="{DynamicResource SliderVerticalThumbWidth}" Height="{DynamicResource SliderVerticalThumbHeight}" FocusVisualMargin="-6,-14,-6,-14">
                                <Thumb.Resources>
                                    <Style TargetType="{x:Type ToolTip}" BasedOn="{StaticResource SliderThumbStyle}" />
                                </Thumb.Resources>
                            </Thumb>
                        </Track.Thumb>
                    </Track>
                </Grid>
            </Grid>
        </Grid>
    </ControlTemplate>
    <Style x:Key="DefaultSliderStyle" TargetType="{x:Type Slider}">
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Vertical">
                <Setter Property="Template" Value="{StaticResource TopLeftCornerRadiusDoubleValueConverter}" />
            </Trigger>
        </Style.Triggers>
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsPressAndHoldEnabled" Value="false" />
        <Setter Property="Background" Value="{DynamicResource SliderTrackFill}" />
        <Setter Property="BorderThickness" Value="{DynamicResource SliderBorderThemeThickness}" />
        <Setter Property="Foreground" Value="{DynamicResource SliderTrackValueFill}" />
        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualMargin" Value="-7,0,-7,0" />
        <Setter Property="CornerRadius" Value="{DynamicResource ControlCornerRadius}" />
        <Setter Property="Template" Value="{StaticResource DefaultToolTipStyle}" />
    </Style>
    <Style x:Key="{x:Type Slider}" TargetType="{x:Type Slider}" BasedOn="{StaticResource DefaultToolTipStyle}" />
</ResourceDictionary>

