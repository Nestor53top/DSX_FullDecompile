<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives" xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Thickness x:Key="TabViewTopHeaderPadding">8,8,0,0</Thickness>
    <Thickness x:Key="TabViewBottomHeaderPadding">8,0,0,8</Thickness>
    <Thickness x:Key="TabViewLeftHeaderPadding">8,8,0,8</Thickness>
    <Thickness x:Key="TabViewRightHeaderPadding">0,8,8,8</Thickness>
    <Thickness x:Key="TabViewHeaderPadding">8,8,0,0</Thickness>
    <Thickness x:Key="TabViewItemHeaderPadding">12,8,10,8</Thickness>
    <Double x:Key="TabViewItemMaxWidth">240</Double>
    <Double x:Key="TabViewItemMinWidth">100</Double>
    <Double x:Key="TabViewItemHeaderFontSize">12</Double>
    <Double x:Key="TabViewItemHeaderIconSize">16</Double>
    <Thickness x:Key="TabViewItemHeaderIconMargin">0,0,10,0</Thickness>
    <Double x:Key="TabViewItemHeaderCloseButtonSize">16</Double>
    <Double x:Key="TabViewItemHeaderCloseFontSize">12</Double>
    <Thickness x:Key="TabViewItemHeaderCloseMargin">10,0,0,0</Thickness>
    <Double x:Key="TabViewItemScrollButtonWidth">29</Double>
    <Double x:Key="TabViewItemScrollButtonHeight">29</Double>
    <Thickness x:Key="TabViewItemScrollButtonPadding">6,4,10,5</Thickness>
    <Double x:Key="TabViewShadowDepth">16</Double>
    <Thickness x:Key="TabViewItemSeparatorMargin">0,6,0,6</Thickness>
    <primitives:CornerRadiusFilterConverter x:Key="TopCornerRadiusFilterConverter" Filter="Top" />
    <primitives:CornerRadiusFilterConverter x:Key="RightCornerRadiusFilterConverter" Filter="Right" />
    <primitives:CornerRadiusFilterConverter x:Key="BottomCornerRadiusFilterConverter" Filter="Bottom" />
    <primitives:CornerRadiusFilterConverter x:Key="LeftCornerRadiusFilterConverter" Filter="Left" />
    <Style x:Key="DefaultTabItemStyle" TargetType="{x:Type TabItem}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="CornerRadius" Value="{DynamicResource OverlayCornerRadius}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabItem}">
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="TabContainer" Value="{DynamicResource TabViewItemHeaderBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource TabViewItemHeaderForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="IconControl" Value="{DynamicResource TabViewItemIconForegroundPointerOver}" Property="Foreground" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Shadow" Value="{DynamicResource {x:Static DropShadow}}" Property="IsShadowEnabled" />
                            <Setter TargetName="TabContainer" Value="{DynamicResource TabViewItemHeaderBackgroundSelected}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource TabViewItemHeaderForegroundSelected}" Property="Foreground" />
                            <Setter TargetName="IconControl" Value="{DynamicResource TabViewItemIconForegroundSelected}" Property="Foreground" />
                            <Setter Property="ZIndex" Value="1" />
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsMouseOver" Value="True" />
                                <Condition Property="IsSelected" Value="True" />
                            </MultiTrigger.Conditions>
                            <Setter TargetName="TabContainer" Value="{DynamicResource TabViewItemHeaderBackgroundSelected}" Property="Background" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource TabViewItemHeaderForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="IconControl" Value="{DynamicResource TabViewItemIconForegroundPointerOver}" Property="Foreground" />
                            <Setter Property="ZIndex" Value="1" />
                        </MultiTrigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="IconControl" Value="{DynamicResource TabViewButtonForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource TabViewItemHeaderForegroundDisabled}" Property="Foreground" />
                        </Trigger>
                        <Trigger Value="{Null}" Property="Icon">
                            <Setter TargetName="IconBox" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <DataTrigger Value="Bottom" Binding="{Binding TabStripPlacement , RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}">
                            <Setter TargetName="TabContainer" Value="{Binding Path=(primitives:ControlHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BottomCornerRadiusFilterConverter}}" Property="CornerRadius" />
                        </DataTrigger>
                        <DataTrigger Value="Left" Binding="{Binding TabStripPlacement , RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}">
                            <Setter TargetName="TabSeparator" Value="{Null}" Property="BorderBrush" />
                            <Setter TargetName="TabContainer" Value="{Binding Path=(primitives:ControlHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource LeftCornerRadiusFilterConverter}}" Property="CornerRadius" />
                        </DataTrigger>
                        <DataTrigger Value="Right" Binding="{Binding TabStripPlacement , RelativeSource={RelativeSource AncestorType={x:Type TabControl}}}">
                            <Setter TargetName="TabSeparator" Value="{Null}" Property="BorderBrush" />
                            <Setter TargetName="TabContainer" Value="{Binding Path=(primitives:ControlHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource RightCornerRadiusFilterConverter}}" Property="CornerRadius" />
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                    <primitives:ThemeShadowChrome Name="Shadow" Depth="{DynamicResource TabViewShadowDepth}" IsShadowEnabled="False" CornerRadius="{Binding ElementName=TabContainer, Path=CornerRadius}">
                        <Border Name="LayoutRoot" Padding="{TemplateBinding Padding}" Margin="-1,0,0,0" SnapsToDevicePixels="True">
                            <Grid>
                                <Border Name="TabSeparator" HorizontalAlignment="Right" Width="1" BorderBrush="{DynamicResource TabViewItemSeparator}" BorderThickness="1" Margin="{DynamicResource TabViewItemSeparatorMargin}" />
                                <Border Name="TabContainer" Column="1" Background="{DynamicResource TabViewItemHeaderBackground}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" IsTemplateFocusTarget="True" Padding="{DynamicResource TabViewItemHeaderPadding}" CornerRadius="{TemplateBinding primitives:ControlHelper.CornerRadius , Converter={StaticResource TopCornerRadiusFilterConverter}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Viewbox Name="IconBox" MaxWidth="{DynamicResource TabViewItemHeaderIconSize}" MaxHeight="{DynamicResource TabViewItemHeaderIconSize}" Margin="{DynamicResource TabViewItemHeaderIconMargin}">
                                            <ContentControl Name="IconControl" Content="{TemplateBinding Icon}" IsTabStop="False" Foreground="{DynamicResource TabViewItemIconForeground}" />
                                        </Viewbox>
                                        <ContentPresenter Name="ContentPresenter" Column="1" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" ContentSource="Header" Foreground="{DynamicResource TabViewItemHeaderForeground}" FontWeight="{TemplateBinding FontWeight}" FontSize="{DynamicResource TabViewItemHeaderFontSize}" Focusable="False" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </primitives:ThemeShadowChrome>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Type TabItem}" TargetType="{x:Type TabItem}" BasedOn="{StaticResource TopCornerRadiusFilterConverter}" />
    <Style x:Key="DefaultTabControlStyle" TargetType="{x:Type TabControl}">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="{DynamicResource TabViewBackground}" />
        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TabControl}">
                    <ControlTemplate.Triggers>
                        <Trigger Property="TabStripPlacement" Value="Top">
                            <Setter TargetName="TabPanel" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="TabStripPlacement" Value="Bottom">
                            <Setter TargetName="headerPanel" Property="Row" Value="1" />
                            <Setter TargetName="contentPanel" Property="Row" Value="0" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="Auto" />
                            <Setter TargetName="TabPanel" Property="VerticalAlignment" Value="Top" />
                            <Setter TargetName="TabPanel" Value="{DynamicResource TabViewBottomHeaderPadding}" Property="Margin" />
                        </Trigger>
                        <Trigger Property="TabStripPlacement" Value="Left">
                            <Setter TargetName="headerPanel" Property="Row" Value="0" />
                            <Setter TargetName="contentPanel" Property="Row" Value="0" />
                            <Setter TargetName="headerPanel" Property="Column" Value="0" />
                            <Setter TargetName="contentPanel" Property="Column" Value="1" />
                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="Auto" />
                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="*" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                            <Setter TargetName="HeaderContentPresenter" Property="Dock" Value="Top" />
                            <Setter TargetName="TabPanel" Property="Dock" Value="Top" />
                            <Setter TargetName="TabPanel" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="TabPanel" Value="{DynamicResource TabViewLeftHeaderPadding}" Property="Margin" />
                            <Setter TargetName="FooterContentPresenter" Property="Dock" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="TabStripPlacement" Value="Right">
                            <Setter TargetName="headerPanel" Property="Row" Value="0" />
                            <Setter TargetName="contentPanel" Property="Row" Value="0" />
                            <Setter TargetName="headerPanel" Property="Column" Value="1" />
                            <Setter TargetName="contentPanel" Property="Column" Value="0" />
                            <Setter TargetName="ColumnDefinition0" Property="Width" Value="*" />
                            <Setter TargetName="ColumnDefinition1" Property="Width" Value="Auto" />
                            <Setter TargetName="RowDefinition0" Property="Height" Value="*" />
                            <Setter TargetName="RowDefinition1" Property="Height" Value="0" />
                            <Setter TargetName="HeaderContentPresenter" Property="Dock" Value="Top" />
                            <Setter TargetName="TabPanel" Property="Dock" Value="Top" />
                            <Setter TargetName="TabPanel" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="TabPanel" Value="{DynamicResource TabViewRightHeaderPadding}" Property="Margin" />
                            <Setter TargetName="FooterContentPresenter" Property="Dock" Value="Bottom" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Grid Name="templateRoot" ClipToBounds="true" TabNavigation="Local" SnapsToDevicePixels="true">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Name="ColumnDefinition0" />
                            <ColumnDefinition Name="ColumnDefinition1" Width="0" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Name="RowDefinition0" Height="Auto" />
                            <RowDefinition Name="RowDefinition1" Height="*" />
                        </Grid.RowDefinitions>
                        <DockPanel Name="headerPanel" ClipToBounds="True" ZIndex="1" Row="0" Column="0" Background="{TemplateBinding Background}">
                            <ContentPresenter Name="HeaderContentPresenter" Dock="Left" Content="{TemplateBinding TabStripHeader}" ContentTemplate="{TemplateBinding TabStripHeaderTemplate}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            <TabPanel Name="TabPanel" Dock="Left" Background="Transparent" Margin="{DynamicResource TabViewTopHeaderPadding}" IsItemsHost="true" />
                            <ContentPresenter Name="FooterContentPresenter" Dock="Right" HorizontalAlignment="Stretch" Content="{TemplateBinding TabStripFooter}" ContentTemplate="{TemplateBinding TabStripFooterTemplate}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </DockPanel>
                        <Border Name="contentPanel" Row="1" Column="0" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" DirectionalNavigation="Contained" TabNavigation="Local">
                            <ContentPresenter Name="PART_SelectedContentHost" Margin="{TemplateBinding Padding}" ContentSource="SelectedContent" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style x:Key="{x:Type TabControl}" TargetType="{x:Type TabControl}" BasedOn="{StaticResource TopCornerRadiusFilterConverter}" />
</ResourceDictionary>

