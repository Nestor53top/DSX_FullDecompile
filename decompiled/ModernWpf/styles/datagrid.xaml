<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:sys="clr-namespace:System;assembly=mscorlib" xmlns:local="clr-namespace:ModernWpf.Controls" xmlns:primitives="clr-namespace:ModernWpf.Controls.Primitives">
    <Double x:Key="DataGridRowMinHeight">32</Double>
    <Style x:Key="DefaultDataGridCellStyle" TargetType="{x:Type DataGridCell}">
