<ContentDialogExample xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="http://schemas.modernwpf.com/2019" PrimaryButtonText="Yes" SecondaryButtonText="Later" DefaultButton="Primary">
    <StackPanel>
        <TextBlock Name="BodyText" Text="" TextWrapping="Wrap" FontSize="16" />
        <Rectangle Name="Rectangle1" Height="20" />
        <Rectangle Name="Rectangle2" Height="1" Fill="White" />
        <Rectangle Name="Rectangle3" Height="20" />
        <TextBlock Name="whatsnewTextblock" Text="What's New:" TextWrapping="Wrap" FontSize="20" FontFamily="Segoe UI Semibold" />
        <ScrollViewer Name="ScrollViewer" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Visible" VerticalContentAlignment="Stretch" HorizontalContentAlignment="Stretch" CanContentScroll="true">
            <StackPanel>
                <TextBlock Name="BodyText2" TextWrapping="Wrap" FontSize="16" />
            </StackPanel>
        </ScrollViewer>
        <Rectangle Height="20" />
        <Label Name="installNowTextblock" Content="Install Now?" HorizontalContentAlignment="Center" FontFamily="Segoe UI Semibold" FontSize="20" />
    </StackPanel>
</ContentDialogExample>

