<UpdateAppWindow xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:DualSenseX" Title="Update History" Height="450" Width="800">
    <Grid>
        <Grid HorizontalAlignment="Left" Width="200">
            <ScrollViewer>
                <StackPanel Margin="0,10">
                    <Button HorizontalAlignment="Center" Content="1.4.4" Width="180" FontSize="18" />
                    <Rectangle Height="20" />
                    <Button HorizontalAlignment="Center" Content="1.4.3" Width="180" FontSize="18" />
                </StackPanel>
            </ScrollViewer>
        </Grid>
        <Grid Width="600" HorizontalAlignment="Right">
            <Label VerticalAlignment="Top" HorizontalAlignment="Left" Content="1.4.4" FontSize="36" Margin="30,10,0,0" />
            <ScrollViewer Margin="30,60">
                <Label Name="versionDes" Margin="20" Foreground="Black" />
            </ScrollViewer>
        </Grid>
    </Grid>
</UpdateAppWindow>

