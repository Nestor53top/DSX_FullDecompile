<App xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:DualSenseX" xmlns:ui="http://schemas.modernwpf.com/2019">
    <App.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ThemeResources />
                <XamlControlsResources />
                <ResourceDictionary Source="ButtonStyle.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="OutputTextBlockStyle" BasedOn="{StaticResource BodyTextBlockStyle}" TargetType="{x:Type TextBlock}">
                <Setter Property="Margin" Value="8,8,0,0" />
            </Style>
        </ResourceDictionary>
    </App.Resources>
</App>

