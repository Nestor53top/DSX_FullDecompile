<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:ModernWpf.Controls" xmlns:ui="http://schemas.modernwpf.com/2019">
    <SharedSizeGroupConverter x:Key="SharedSizeGroupConverter" />
    <Style x:Key="{x:Type local:RadioMenuItem}" TargetType="{x:Type local:RadioMenuItem}">
        <Setter Property="Background" Value="{DynamicResource MenuFlyoutItemRevealBackground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource MenuFlyoutItemRevealBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource MenuFlyoutItemRevealBorderThickness}" />
        <Setter Property="Foreground" Value="{DynamicResource MenuFlyoutItemForeground}" />
        <Setter Property="Padding" Value="{DynamicResource MenuFlyoutItemThemePaddingNarrow}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="PanningMode" Value="Both" />
        <Setter Property="IsFlicksEnabled" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:RadioMenuItem}">
                    <ControlTemplate.Resources>
                        <StreamGeometry Name="RadioBullet">M 10 6.25 C 10.514322 6.25 11 6.347656 11.455078 6.542969 C 11.910807 6.738281 12.30957 7.006836 12.651367 7.348633 C 12.993164 7.69043 13.261719 8.089193 13.457031 8.544922 C 13.652344 9 13.75 9.485678 13.75 10 C 13.75 10.520834 13.652344 11.007487 13.457031 11.459961 C 13.261719 11.912436 12.993164 12.30957 12.651367 12.651367 C 12.30957 12.993164 11.910807 13.261719 11.455078 13.457031 C 11 13.652344 10.514322 13.75 10 13.75 C 9.479166 13.75 8.992513 13.652344 8.540039 13.457031 C 8.087564 13.261719 7.69043 12.993164 7.348633 12.651367 C 7.006836 12.30957 6.738281 11.912436 6.542969 11.459961 C 6.347656 11.007487 6.25 10.520834 6.25 10 C 6.25 9.485678 6.347656 9 6.542969 8.544922 C 6.738281 8.089193 7.006836 7.69043 7.348633 7.348633 C 7.69043 7.006836 8.087564 6.738281 8.540039 6.542969 C 8.992513 6.347656 9.479166 6.25 10 6.25 Z</StreamGeometry>
                    </ControlTemplate.Resources>
                    <ControlTemplate.Triggers>
                        <Trigger Value="{Null}" Property="Icon">
                            <Setter TargetName="IconRoot" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="InputGestureText" Value="">
                            <Setter TargetName="KeyboardAcceleratorTextBlock" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemRevealBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemRevealBorderBrushPointerOver}" Property="BorderBrush" />
                            <Setter TargetName="IconContent" Value="{DynamicResource MenuFlyoutItemForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource MenuFlyoutItemForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="CheckGlyph" Value="{DynamicResource ToggleMenuFlyoutItemCheckGlyphForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="KeyboardAcceleratorTextBlock" Value="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForegroundPointerOver}" Property="Foreground" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemRevealBackgroundPressed}" Property="Background" />
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemRevealBorderBrushPressed}" Property="BorderBrush" />
                            <Setter TargetName="IconContent" Value="{DynamicResource MenuFlyoutItemForegroundPressed}" Property="Foreground" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource MenuFlyoutItemForegroundPressed}" Property="Foreground" />
                            <Setter TargetName="CheckGlyph" Value="{DynamicResource ToggleMenuFlyoutItemCheckGlyphForegroundPressed}" Property="Foreground" />
                            <Setter TargetName="KeyboardAcceleratorTextBlock" Value="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForegroundPressed}" Property="Foreground" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemBackgroundDisabled}" Property="Background" />
                            <Setter TargetName="LayoutRoot" Value="{DynamicResource MenuFlyoutItemRevealBorderBrushDisabled}" Property="BorderBrush" />
                            <Setter TargetName="IconContent" Value="{DynamicResource MenuFlyoutItemForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource MenuFlyoutItemForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="CheckGlyph" Value="{DynamicResource ToggleMenuFlyoutItemCheckGlyphForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="KeyboardAcceleratorTextBlock" Value="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForegroundDisabled}" Property="Foreground" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Border Name="LayoutRoot" SnapsToDevicePixels="true" Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <Grid Name="AnimationRoot">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" SharedSizeGroup="{TemplateBinding Visibility , Converter={StaticResource SharedSizeGroupConverter}, ConverterParameter=MenuItemCheckColumnGroup}" />
                                <ColumnDefinition Width="Auto" SharedSizeGroup="{TemplateBinding Visibility , Converter={StaticResource SharedSizeGroupConverter}, ConverterParameter=MenuItemIconColumnGroup}" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIconFallback Name="CheckGlyph" FontFamily="{DynamicResource SymbolThemeFontFamily}" Data="{StaticResource RadioBullet}" FontSize="16" Foreground="{DynamicResource ToggleMenuFlyoutItemCheckGlyphForeground}" Opacity="0" Width="16" Margin="0,0,12,0" />
                            <Viewbox Name="IconRoot" Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Width="16" Height="16" Margin="0,0,12,0">
                                <ContentPresenter Name="IconContent" ContentSource="Icon" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            </Viewbox>
                            <ContentPresenter Name="ContentPresenter" Column="2" ContentSource="Header" RecognizesAccessKey="True" Foreground="{TemplateBinding Foreground}" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                            <TextBlock Name="KeyboardAcceleratorTextBlock" Column="3" Style="{DynamicResource CaptionTextBlockStyle}" Text="{TemplateBinding InputGestureText}" Margin="24,0,0,0" Foreground="{DynamicResource MenuFlyoutItemKeyboardAcceleratorTextForeground}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

