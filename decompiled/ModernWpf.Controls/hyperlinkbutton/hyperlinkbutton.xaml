<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:local="clr-namespace:ModernWpf.Controls">
    <Thickness x:Key="HyperlinkButtonPadding">0,6,0,7</Thickness>
    <Style x:Key="{x:Type local:HyperlinkButton}" TargetType="{x:Type local:HyperlinkButton}">
        <Style.Triggers>
            <Trigger Property="IsEnabled" Value="true">
                <Setter Property="Cursor" Value="Hand" />
            </Trigger>
        </Style.Triggers>
        <Setter Property="Background" Value="{DynamicResource HyperlinkButtonBackground}" />
        <Setter Property="Foreground" Value="{DynamicResource HyperlinkButtonForeground}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HyperlinkButtonBorderBrush}" />
        <Setter Property="BorderThickness" Value="{DynamicResource HyperlinkButtonBorderThemeThickness}" />
        <Setter Property="Padding" Value="{StaticResource HyperlinkButtonPadding}" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="FontFamily" Value="{DynamicResource ContentControlThemeFontFamily}" />
        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
        <Setter Property="UseSystemFocusVisuals" Value="{DynamicResource UseSystemFocusVisuals}" />
        <Setter Property="FocusVisualMargin" Value="-3" />
        <Setter Property="FocusVisualStyle" Value="{DynamicResource {x:Static FocusVisualStyle}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:HyperlinkButton}">
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource HyperlinkButtonForegroundPointerOver}" Property="Foreground" />
                            <Setter TargetName="Background" Value="{DynamicResource HyperlinkButtonBackgroundPointerOver}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource HyperlinkButtonBorderBrushPointerOver}" Property="BorderBrush" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource HyperlinkButtonForegroundPressed}" Property="Foreground" />
                            <Setter TargetName="Background" Value="{DynamicResource HyperlinkButtonBackgroundPressed}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource HyperlinkButtonBorderBrushPressed}" Property="BorderBrush" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ContentPresenter" Value="{DynamicResource HyperlinkButtonForegroundDisabled}" Property="Foreground" />
                            <Setter TargetName="Background" Value="{DynamicResource HyperlinkButtonBackgroundDisabled}" Property="Background" />
                            <Setter TargetName="Border" Value="{DynamicResource HyperlinkButtonBorderBrushDisabled}" Property="BorderBrush" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Border Name="Background" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                        <Border Name="Border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter Name="ContentPresenter" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}" Focusable="False" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}">
                                <ContentPresenter.Resources>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter x:Key="{x:Type TextBlock}" Property="TextDecorations" Value="Underline" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>
                        </Border>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

