<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:ui="http://schemas.modernwpf.com/2019" xmlns:local="clr-namespace:ModernWpf.Controls">
    <Style x:Key="{x:Type local:AppBarSeparator}" TargetType="{x:Type local:AppBarSeparator}">
        <Setter Property="Foreground" Value="{DynamicResource AppBarSeparatorForeground}" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type local:AppBarSeparator}">
                    <ControlTemplate.Triggers>
                        <Trigger SourceName="ApplicationViewStatesListener" Property="CurrentStateName" Value="Overflow">
                            <Setter TargetName="SeparatorRectangle" Property="Width" Value="NaN" />
                            <Setter TargetName="SeparatorRectangle" Property="HorizontalAlignment" Value="Stretch" />
                            <Setter TargetName="SeparatorRectangle" Property="Height" Value="1" />
                            <Setter TargetName="SeparatorRectangle" Property="Margin" Value="12,4,12,4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                    <Grid Name="SeparatorRectangle" Width="1" Height="20" Background="{TemplateBinding Foreground}" Margin="16,10,15,10" VerticalAlignment="Top" SnapsToDevicePixels="True">
                        <Grid.VisualStateGroups>
                            <VisualStateGroup x:Name="ApplicationViewStates" Listener="{VisualStateGroupListener Name=ApplicationViewStatesListener}">
                                <VisualState x:Name="FullSize" />
                                <VisualState x:Name="Compact" />
                                <VisualState x:Name="Overflow" />
                            </VisualStateGroup>
                        </Grid.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>

