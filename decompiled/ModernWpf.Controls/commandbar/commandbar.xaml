                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames TargetName="OverflowContentRoot" TargetProperty="Visibility">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{Static Collapsed}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="SecondaryCommandsOnly">
