                                        <BooleanAnimationUsingKeyFrames TargetName="PopupDownSpinButton" TargetProperty="IsEnabled">
                                            <DiscreteBooleanKeyFrame KeyTime="0" Value="False" />
                                        </BooleanAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </Grid.VisualStateGroups>
                        <Grid.Resources>
